# LAST CALL — all env vars are OPTIONAL. The app fully works with none of them.
# With zero env: StaticRepo serves data/seed.json, the scraper no-ops loudly,
# and the cron route returns 503 with setup help.

# Neon Postgres connection string. Set this to switch from the bundled seed.json
# (StaticRepo) to a live database (DrizzleRepo).
DATABASE_URL=

# Anthropic API key. Powers the AI deal-extraction pipeline (Phase 5).
# Without it, `pnpm scrape` and the cron route no-op and log loudly.
ANTHROPIC_API_KEY=

# Shared secret guarding /api/cron/refresh (Bearer token) and /admin (?key=).
# Without it, the cron route returns 503 with setup instructions.
CRON_SECRET=
